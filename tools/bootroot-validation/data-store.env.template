# data-store.env.template — Environment variables for Bootroot mTLS validation
#
# Copy this file to data-store.env and adjust paths as needed.
# All TLS_* paths are relative to the working directory unless absolute.

# --- TLS Certificate Inputs ---
# Server certificate (leaf cert, PEM format)
TLS_CERT_PATH=./checked-fixtures/leaf.pem

# Server private key (PEM format, PKCS#1 or PKCS#8)
TLS_KEY_PATH=./checked-fixtures/leaf.key

# CA bundle for client verification (PEM format).
# For Bootroot-style validation this MUST contain the intermediate CA
# followed by the root CA (order: intermediate + root).
TLS_CA_BUNDLE_PATH=./checked-fixtures/ca-bundle.pem

# --- Giganto Server Settings ---
# Configuration file path
GIGANTO_CONFIG=./validation-config.toml

# GraphQL server listen address
GRAPHQL_SRV_ADDR=[::]:8443

# Data directory (must exist before startup)
GIGANTO_DATA_DIR=/tmp/giganto-validation-data

# Export directory
GIGANTO_EXPORT_DIR=/tmp/giganto-validation-export
